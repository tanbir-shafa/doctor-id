# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env
.env.local
.env.*.local

# vercel (unused, kept so accidental .vercel files don't ship)
.vercel

# IDE
.idea/
.vscode/

# typescript
*.tsbuildinfo
next-env.d.ts

# offline data snapshots (scripts/fetch-popular-diagnostic.ts etc.)
# Ignore each snapshot dir individually (so a negation can re-include one).
/data/*
# ...except the curated chamber-location catalog — small reference data (47 rows),
# committed and seeded into the Chamber collection by scripts/seed.ts.
!/data/chambers/
.pem
deploy_key.pub
deploy_key
