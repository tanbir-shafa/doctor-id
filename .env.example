# Copy to .env.local for local dev. Never commit secrets.

# --- MongoDB (Atlas in prod; docker-compose Mongo as fallback in dev) ---
MONGO_URI=mongodb://localhost:27017/doctor-id-dev

# --- NextAuth (Auth.js v5) ---
# Generate with: openssl rand -hex 32
AUTH_SECRET=
# Public URL of the app. Must match the protocol+host the browser uses.
AUTH_URL=http://localhost:3000
# Google OAuth (optional — credentials login works without these)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# --- AWS (S3 uploads + SES email) ---
AWS_REGION=ap-south-1
# Credentials resolve by NODE_ENV: non-production uses these static keys;
# production ignores them and assumes the cross-account role below.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Production-only: cross-account STS role. Base creds come from the instance's
# IAM role via the default chain (EC2 instance profile, or ECS task role).
AWS_ASSUME_ROLE_ARN=
AWS_S3_EXTERNAL_ID=
# Legacy single bucket (ingestion + public-bucket fallback).
S3_BUCKET=doctor-id-uploads
# Multi-bucket: public = profile/cover photos (stable URL); private = identity
# docs (selfie, verification) read via presigned GET. Public falls back to S3_BUCKET.
AWS_PUBLIC_BUCKET_NAME=
AWS_PRIVATE_BUCKET_NAME=
# Upload limits + presigned-GET expiry (seconds).
MAX_FILE_SIZE_MB=10
MAX_FILES_COUNT=5
IMAGE_UPLOAD_PRESIGN_EXPIRES_SECONDS=86400
# --- AWS SES (transactional email; uses the same AWS creds as S3 above) ---
# SES-verified sender. While SES is in sandbox, recipients must also be verified.
SES_FROM_ADDRESS=no-reply@doctor.id.bd
# Optional display name → From: "doctor.id.bd" <no-reply@doctor.id.bd>
SES_FROM_NAME=doctor.id.bd
SES_REPLY_TO=support@doctor.id.bd
# Optional SES configuration set (event publishing / dedicated IP pool).
SES_CONFIG_SET=
# Optional DynamoDB table (partition key `email`) for the app-level suppression
# list checked before each send. Leave blank to disable that pre-send check —
# SES still honors its own native account-level suppression list.
SES_SUPPRESSION_TABLE=

# --- Upstash Redis (rate-limit + ephemeral cache) ---
# https://console.upstash.com → create a Redis DB → copy the REST creds.
# Uses the REST/HTTPS API (@upstash/redis), which @upstash/ratelimit requires.
# This runs fine on a long-running EC2 server — no TCP/ioredis client is needed
# (the same Upstash DB also exposes a TCP endpoint; we deliberately use REST).
# When unset in dev, rate-limiters fall back to no-op so dev isn't blocked.
# REQUIRED in production: the app refuses to boot without these (rate limiting
# is the backbone of the OTP/login/API abuse defenses — it must not silently
# disable). When unreachable in prod, limiters fail CLOSED (deny).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Cloudflare Turnstile (human-verification on OTP / email-send forms) ---
# https://dash.cloudflare.com → Turnstile → add a site → copy both keys.
# Gates register / login / forgot-password before any SMS or email is sent.
# When the SECRET is unset: dev no-ops to "pass"; production FAILS CLOSED
# (the protected forms are disabled until you configure it).
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- SMS provider ---
# Which gateway sends SMS: "ssl" (SSL Wireless iSMS Plus v3, default) or
# "mdl" (legacy in-house gateway, kept as a fallback).
SMS_PROVIDER=ssl

# --- SSL Wireless iSMS Plus (primary SMS provider) ---
# v3 JSON API. The request IP must be whitelisted in the SSL portal before
# live sends succeed. When token/sid are unset, OTP + campaign SMS are
# printed to the server console (dev no-op), so flows stay testable offline
# — same pattern as SES.
SSL_SMS_API_TOKEN=
SSL_SMS_SID=
SSL_SMS_API_BASE_URL=https://smsplus.sslwireless.com/api/v3

# --- MDL SMS gateway (LEGACY fallback — set SMS_PROVIDER=mdl to use) ---
# In-house GET wrapper to MDL. When any of these are unset, the MDL path
# prints to the server console instead of dispatching.
MDL_SMS_API_BASE_URL=
MDL_SMS_API_KEY=
MDL_SMS_API_SENDER_ID=DoctorID

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Comma-separated emails granted admin role at signup. Used by the seed script too.
ADMIN_EMAILS=

# --- Security / edge ---
# Trusted reverse-proxy hops in front of the app. EC2 + nginx = 1. The real
# client IP is taken from X-Real-IP / the right-most XFF hop accordingly, so a
# client can't spoof the left-most XFF to dodge per-IP rate limits. Bump if you
# add a CDN/LB in front of nginx (e.g. Cloudflare → nginx → app = 2).
TRUSTED_PROXY_HOPS=1
# Extra origins (beyond NEXT_PUBLIC_APP_URL) allowed to call /api/v1 and invoke
# Server Actions. Comma-separated absolute origins, e.g.
# https://www.doctor.id.bd,https://staging.doctor.id.bd
EXTRA_ALLOWED_ORIGINS=
# App-wide circuit breaker: max OTP/transactional SMS sends per hour across ALL
# users (bulk campaigns are exempt). Coarse safety ceiling above peak volume.
SMS_GLOBAL_HOURLY_CAP=2000

# --- Offline scrapers (scripts/fetch-popular-diagnostic.ts) ---
# Public token for api.populardiagnostic.com used by the one-shot snapshot script.
POPULAR_API_TOKEN=

# --- Observability (optional) ---
# Sentry / OpenTelemetry wiring lives in Step 10; placeholder so .env.example
# documents the full shape we expect at deploy time.
SENTRY_DSN=
